{
  "name": "portfolio",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "blog:build": "node scripts/build-blog.mjs",
    "start": "node scripts/build-blog.mjs && concurrently \"npx @tailwindcss/cli -i ./tailwind.input.css -o ./src/tailwind.output.css --watch\" \"ng serve\"",
    "build": "node scripts/build-blog.mjs && npx @tailwindcss/cli -i ./tailwind.input.css -o ./src/tailwind.output.css && ng build",
    "tw:watch": "npx @tailwindcss/cli -i ./tailwind.input.css -o ./src/tailwind.output.css --watch",
    "tw:build": "npx @tailwindcss/cli -i ./tailwind.input.css -o ./src/tailwind.output.css",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "serve:ssr:portfolio": "node dist/portfolio/server/server.mjs"
  },
  "private": true,
  "packageManager": "npm@11.5.2",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/platform-server": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@angular/ssr": "^21.2.7",
    "@anthropic-ai/sdk": "^0.90.0",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "dotenv": "^17.4.2",
    "express": "^5.1.0",
    "gray-matter": "^4.0.3",
    "gsap": "^3.15.0",
    "marked": "^18.0.3",
    "rxjs": "~7.8.0",
    "tailwindcss": "^4.2.2",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.7",
    "@angular/cli": "^21.2.7",
    "@angular/compiler-cli": "^21.2.0",
    "@tailwindcss/cli": "^4.2.2",
    "@types/express": "^5.0.1",
    "@types/marked": "^5.0.2",
    "@types/node": "^20.17.19",
    "concurrently": "^9.2.1",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
